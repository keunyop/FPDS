{
  "surface": "public_app",
  "access": "anonymous",
  "default_locale": "en",
  "routes": [
    {
      "route": "/",
      "route_id": "public.home",
      "shell_dir": "route-shells/home",
      "resource_key": "public_navigation.home"
    },
    {
      "route": "/products",
      "route_id": "public.products",
      "shell_dir": "route-shells/products",
      "resource_key": "public_navigation.products"
    },
    {
      "route": "/products/[productId]",
      "route_id": "public.product_detail",
      "shell_dir": "route-shells/products",
      "resource_key": "public_navigation.products"
    },
    {
      "route": "/dashboard",
      "route_id": "public.dashboard",
      "shell_dir": "route-shells/dashboard",
      "resource_key": "public_navigation.dashboard"
    },
    {
      "route": "/methodology",
      "route_id": "public.methodology",
      "shell_dir": "route-shells/methodology",
      "resource_key": "public_navigation.methodology"
    }
  ]
}
