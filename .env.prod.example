# FPDS production environment example
# Keep this file placeholder-only and move real values to the production secret store.

FPDS_ENV=prod
FPDS_RUNTIME_LABEL=prod

# Origins
FPDS_PUBLIC_WEB_ORIGIN=https://public.fpds.example.com
FPDS_ADMIN_WEB_ORIGIN=https://admin.fpds.example.com
FPDS_PUBLIC_API_ORIGIN=https://api.fpds.example.com
FPDS_ADMIN_API_ORIGIN=https://api.fpds.example.com
FPDS_INTERNAL_API_ORIGIN=https://api-internal.fpds.example.com

# Data plane
FPDS_DATABASE_URL=postgres://fpds_prod_user:replace-me@prod-db-host:5432/fpds_prod
FPDS_DATABASE_SCHEMA=public
FPDS_VECTOR_BACKEND=pgvector
FPDS_VECTOR_NAMESPACE=fpds-prod
FPDS_VECTOR_EMBEDDING_MODEL=fpds-hash-lexical-v1
FPDS_VECTOR_EMBEDDING_DIMENSIONS=64
FPDS_OBJECT_STORAGE_DRIVER=s3-compatible
FPDS_OBJECT_STORAGE_ENDPOINT=https://storage.fpds.example.com
FPDS_OBJECT_STORAGE_REGION=replace-me
FPDS_OBJECT_STORAGE_BUCKET=fpds-prod-private
FPDS_OBJECT_STORAGE_PREFIX=prod
FPDS_OBJECT_STORAGE_ACCESS_MODE=private
FPDS_OBJECT_STORAGE_SIGNED_URL_MODE=internal-only
FPDS_SNAPSHOT_OBJECT_PREFIX=snapshots
FPDS_PARSED_OBJECT_PREFIX=parsed
FPDS_EXTRACTION_OBJECT_PREFIX=extracted
FPDS_NORMALIZED_OBJECT_PREFIX=normalized
FPDS_VALIDATION_OBJECT_PREFIX=validated
FPDS_PARSER_INTERMEDIATE_PREFIX=intermediate
FPDS_EVIDENCE_PREFIX_ROOT=prod
FPDS_EVIDENCE_RETENTION_CLASS=hot

# Auth and secrets
FPDS_ADMIN_AUTH_MODE=server-session
FPDS_ADMIN_SESSION_SECRET=replace-me-prod-session-secret
FPDS_ADMIN_CSRF_SECRET=replace-me-prod-csrf-secret
FPDS_STORAGE_ACCESS_KEY=replace-me-prod-storage-access-key
FPDS_STORAGE_SECRET_KEY=replace-me-prod-storage-secret-key
FPDS_CRAWLER_SHARED_SECRET=replace-me-prod-crawler-secret

# Fetch, model, and integration behavior
FPDS_SOURCE_FETCH_MODE=live
FPDS_SOURCE_FETCH_ALLOWLIST=replace-me-with-approved-banking-domains
FPDS_SOURCE_FETCH_BLOCK_PRIVATE_NETWORKS=true
FPDS_SOURCE_FETCH_TIMEOUT_SECONDS=90
FPDS_SOURCE_BROWSER_FALLBACK_DOMAINS=bmo.com,www.bmo.com
FPDS_SOURCE_BROWSER_FALLBACK_TIMEOUT_SECONDS=120
FPDS_SOURCE_BROWSER_EXECUTABLE=
FPDS_SOURCE_COLLECTION_STAGE_TIMEOUT_SECONDS=1800
FPDS_LLM_PROVIDER=openai
FPDS_LLM_MODEL=gpt-5.4
FPDS_LLM_API_KEY=replace-me-prod-llm-api-key
FPDS_BXPF_MODE=live
FPDS_BXPF_BASE_URL=https://bxpf-prod-placeholder.example
FPDS_BXPF_CLIENT_ID=replace-me-prod-bxpf-client-id
FPDS_BXPF_CLIENT_SECRET=replace-me-prod-bxpf-client-secret

# Security and browser policy
FPDS_ALLOWED_PUBLIC_ORIGINS=https://public.fpds.example.com
FPDS_ALLOWED_ADMIN_ORIGINS=https://admin.fpds.example.com
FPDS_SECURITY_HEADERS_ENABLED=true
FPDS_COOKIE_SECURE=true
FPDS_COOKIE_SAMESITE=Lax
FPDS_CSRF_PROTECTION_ENABLED=true

# Observability
FPDS_LOG_LEVEL=info
FPDS_REQUEST_ID_HEADER=x-request-id
FPDS_MONITORING_PROVIDER=sentry
FPDS_MONITORING_DSN=replace-me-prod-monitoring-dsn
