        {
          "field_name": "term_rate_table",
          "candidate_value": "[{\"minimum_deposit\": \"10000.00\", \"notes\": null, \"rate\": \"2.80\", \"term_label\": \"3 months\", \"term_length_days\": 90}]",
          "evidence_chunk_id": "chunk-b14b1bb77731e3a4",
          "evidence_text_excerpt": "About the offer\nTo get the offer:\nOpen your first Scotia High Interest Savings Account (HISA). You must not currently have a Momentum PLUS Savings Account or a Scotia HISA or have held either account within the last 2 years\nYour Total Relationship Balance 1 must be over $10,000 CAD each day to earn interest on your Scotia HISA for that day. This is calculated by adding up the daily closing balances in your Scotia HISA and all your other eligible accounts\nThen, for the first 3 months you have your account, you\u2019ll earn both the:\nPromotional rate of 2.80% 2\nRegular interest rate of up to 2.20% 3\nInterest will be applied to your Scotia HISA only when:\nThe Total Relationship Balance is greater than $10,000 CAD\nYour Scotia HISA is open and in good standing",
          "source_document_id": "src-scotia-html-d938019b2d45b48a",
          "source_snapshot_id": "snap-20ee6f157640bf13",
          "citation_confidence": 0.78,
          "model_execution_id": "modelexec-ea47c4512c5f3275",
          "anchor_type": "section",
          "anchor_value": "about-the-offer",
          "page_no": null,
          "chunk_index": 2
        },
        {
          "field_name": "interest_calculation_method",
          "candidate_value": "For the interest calculation made on a day that is not a business day, the daily closing balance of the HISA on the previous business day will be used.",
          "evidence_chunk_id": "chunk-ef5d167248a2005b",
          "evidence_text_excerpt": "Banking or your Mobile App on the day after 7th business day after the end of each month. For the interest calculation made on a day that is not a business day, the daily closing balance of the HISA on the previous business day will be used. If you close your HISA within 7 business days of opening it, you will forgo any Promotional Rate interest earned. HISA\u00a0must be open and in good standing at the time of any interest payment.\nAfter the Promotional Rate Period ends, any balance in your HISA will earn interest at the then current posted Regular Interest Rate for the HISA (assuming your Total Relationship Balance is greater than CAD $10,000). Refer to www.scotiabank.com/rates for current interest rates, which are subject to change. The Regular Interest Rate is an annual rate and interest is calculated daily, paid monthly.\u00a0 Please refer to the product terms and conditions (",
          "source_document_id": "src-scotia-html-d938019b2d45b48a",
          "source_snapshot_id": "snap-20ee6f157640bf13",
          "citation_confidence": 0.98,
