          "field_name": "post_maturity_interest_rate",
          "candidate_value": "inal document to: B2B Bank 199 Bay Street, Suite 600 PO Box 279 STN Commerce Court Toronto ON M5L 0A2 For renewals, fax documents to 1.888.946.3448 or mail to B2B Bank.",
          "value_type": "string",
          "confidence": 0.73,
          "extraction_method": "heuristic_post_maturity_interest_rate",
