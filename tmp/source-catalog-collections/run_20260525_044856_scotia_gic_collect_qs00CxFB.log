        {
          "field_name": "minimum_balance",
          "candidate_value": "30000.00",
          "evidence_chunk_id": "chunk-6d28c435fca5a23d",
          "evidence_text_excerpt": "How can I get my Ultimate Package monthly account fee waived?\nYour monthly\u00a0account fee will still be waived by\u00a0maintaining\u00a0a minimum daily closing balance of $6,000 in your Ultimate Package for the entire month.\nAs\u00a0of March 20th, we are\u00a0also\u00a0introducing a more flexible way to waive monthly account fees by\u00a0maintaining\u00a0a Total Relationship Balance of $100,000\u00a0or more\u00a0across\u00a0chequing, savings, and retail investments. 5 This will replace the current\u00a0$30,000\u00a0minimum\u00a0balance requirement across\u00a0just\u00a0your Ultimate Package and\u00a0Momentum PLUS Savings Account.",
          "source_document_id": "src-scotia-html-00d5a2001b2f2e5d",
          "source_snapshot_id": "snap-14f4ae33222fed0a",
          "citation_confidence": 0.55,
          "model_execution_id": "modelexec-4c8223b0e745b0d6",
          "anchor_type": "section",
          "anchor_value": "how-can-i-get-my-ultimate-package-monthly-account-fee-waived",
