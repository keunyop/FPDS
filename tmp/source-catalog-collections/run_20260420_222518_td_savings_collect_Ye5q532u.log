        {
          "field_name": "promotional_period_text",
          "candidate_value": "Make small business purchases with a wave of your TD Business Credit Card! Contactless payment is a fast, convenient and secure way to make your small business purchases directly with just a wave of your TD Business Credit Card. TD Business Credit Cards with chip & PIN technology",
          "value_type": "string",
          "confidence": 0.55,
          "extraction_method": "heuristic_text",
          "source_document_id": "src-td-html-8b202822682e56c8",
          "source_snapshot_id": "snap-9a9ef0938922d029",
          "evidence_chunk_id": "chunk-742d595db1afcb6b",
          "evidence_text_excerpt": "Make small business purchases with a wave of your TD Business Credit Card!\nContactless payment is a fast, convenient and secure way to make your small business purchases directly with just a wave of your TD Business Credit Card. TD Business Credit Cards with chip & PIN technology come equipped with this capability. Look for the contactless symbol on merchant point-of-sale terminals, just like the symbol you see on your Card.",
          "anchor_type": "section",
          "anchor_value": "make-small-business-purchases-with-a-wave-of-your-td-business-credit-card",
          "page_no": null,
          "chunk_index": 9,
