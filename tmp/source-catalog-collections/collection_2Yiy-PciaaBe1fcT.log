        {
          "field_name": "non_redeemable_flag",
          "candidate_value": "true",
          "evidence_chunk_id": "chunk-54bdae8600c17059",
          "evidence_text_excerpt": "Non-Cashable\u00a0GICs\nEnjoy a guaranteed rate of interest return that is generally higher than a cashable GIC, by locking in your money for a set period of time.\nRate: % per annum on a 1 year term\nTerms: 30 days to 5 years\nMinimum investment: $500 3\nCashability: Non-redeemable\nType: Fixed-rate\nPlan: Registered or non-registered\nGreat for: Investors looking for a higher guaranteed interest rate and want to invest until maturity.",
          "source_document_id": "src-td-html-d7634d8b98db2ea7",
          "source_snapshot_id": "snap-7eb91404d2dbce3d",
          "citation_confidence": 0.64,
          "model_execution_id": "modelexec-5241fd7794ac67ef",
