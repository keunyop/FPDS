          "field_name": "promotional_period_text",
          "candidate_value": "CIBC eAdvantage\u00ae Savings Account interest rates \u24d8 This offer is only available to clients opening their first CIBC eAdvantage\u00ae Savings Account (\u201c eSA \u201d).",
          "value_type": "string",
