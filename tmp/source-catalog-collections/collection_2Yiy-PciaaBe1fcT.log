        {
          "field_name": "redeemable_flag",
          "candidate_value": "true",
          "evidence_chunk_id": "chunk-9aded8fc44b0d941",
          "evidence_text_excerpt": "How do GICs work in Canada?\nChoose your plan and term: Grow your money tax-deferred or tax-free when you invest in a registered plan like an RRSP 1 or TFSA 2 .\u00a0Then choose how long you want to invest your money depending on your investment goals.\nSelect a GIC: Fixed-rate GICs offer guaranteed returns, equity-linked GICs provide growth potential, and foreign currency GICs diversify investments in foreign currency.\nCashability: You can choose a cashable or redeemable GIC, if you want the flexibility of cashing out early before the end of the term.",
          "source_document_id": "src-td-html-d7634d8b98db2ea7",
          "source_snapshot_id": "snap-7eb91404d2dbce3d",
          "citation_confidence": 0.55,
          "model_execution_id": "modelexec-5241fd7794ac67ef",
          "anchor_type": "section",
