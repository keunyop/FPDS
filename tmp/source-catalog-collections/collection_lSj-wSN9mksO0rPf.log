        {
          "field_name": "amortization_text",
          "candidate_value": "CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669 \u4ea7\u54c1\u6458\u8981 \u5b89\u5fc3\u5f53\u4e0b\uff0c\u4fdd\u969c\u672a\u6765\u3002 \u9009\u62e9CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669\u7684\u7406\u7531 \u5408\u9002\u7684\u4fdd\u9669\u80fd\u591f\u5e26\u6765\u5b89\u5fc3\u4fdd\u969c\uff0c\u5373\u4f7f\u672a\u6765\u4e2a\u4eba\u6536\u5165\u53d7\u5230\u5f71\u54cd\uff0c\u4e5f\u80fd\u8ba9\u81ea\u5df1\u548c\u5bb6\u4eba\u6709\u623f\u53ef\u4f4f\uff0c\u5b89\u5fc3\u65e0\u5fe7\u3002CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd \u9669\u662f\u4e00\u79cd\u503a\u6743\u4eba\u56e2\u4f53\u4fdd\u9669\uff0c\u7531Canada Life\u4fdd\u9669\u516c\u53f8\u627f\u4fdd\u3002\u8be5\u4fdd\u9669\u53ef\u5728\u60a8\u8eab\u6545\u6216\u7f79\u60a3\u4fdd\u5355\u6db5\u76d6\u7684\u91cd\u5927\u75be\u75c5\u65f6\uff0c\u5e2e\u52a9\u507f\u8fd8\u6216\u51cf\u5c11 \u60a8\u7684\u623f\u5c4b\u8d37\u6b3e*\u3002 \u5982\u679c\u60a8\u56e0\u4f24\u75c5\u6216\u975e\u81ea\u613f\u5931\u4e1a\u800c\u65e0\u6cd5\u5de5\u4f5c\uff0c\u4fdd\u9669\u8fd8\u53ef\u4ee5\u534f\u52a9\u60a8\u652f\u4ed8\u90e8\u5206\u623f\u5c4b\u8d37\u6b3e\u8fd8\u6b3e\u3002 \u9879\u76ee \u63cf\u8ff0 \u4fdd\u969c \u5f53\u4e2a\u4eba\u56e0\u4f24\u6b8b\u65e0\u6cd5\u5de5\u4f5c\u3001\u906d\u9047\u975e\u81ea\u613f\u5931\u4e1a\u3001\u786e\u8bca\u627f\u4fdd\u8303\u56f4\u5185\u7684\u91cd\u5927\u75be\u75c5\u6216\u8eab\u6545\u65f6\uff0c\u63d0\u4f9bCIBC\u623f\u8d37 \u8d22\u52a1\u4fdd\u969c\u3002 \u5373\u65f6\u627f\u4fdd \u7533\u8bf7\u8868\u4e2d\u6240\u6709",
          "evidence_chunk_id": "chunk-d7e0db497dcdc2cc",
          "evidence_text_excerpt": "CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669\n\u4ea7\u54c1\u6458\u8981\n\u5b89\u5fc3\u5f53\u4e0b\uff0c\u4fdd\u969c\u672a\u6765\u3002\n\u9009\u62e9CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669\u7684\u7406\u7531\n\u5408\u9002\u7684\u4fdd\u9669\u80fd\u591f\u5e26\u6765\u5b89\u5fc3\u4fdd\u969c\uff0c\u5373\u4f7f\u672a\u6765\u4e2a\u4eba\u6536\u5165\u53d7\u5230\u5f71\u54cd\uff0c\u4e5f\u80fd\u8ba9\u81ea\u5df1\u548c\u5bb6\u4eba\u6709\u623f\u53ef\u4f4f\uff0c\u5b89\u5fc3\u65e0\u5fe7\u3002CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\n\u9669\u662f\u4e00\u79cd\u503a\u6743\u4eba\u56e2\u4f53\u4fdd\u9669\uff0c\u7531Canada Life\u4fdd\u9669\u516c\u53f8\u627f\u4fdd\u3002\u8be5\u4fdd\u9669\u53ef\u5728\u60a8\u8eab\u6545\u6216\u7f79\u60a3\u4fdd\u5355\u6db5\u76d6\u7684\u91cd\u5927\u75be\u75c5\u65f6\uff0c\u5e2e\u52a9\u507f\u8fd8\u6216\u51cf\u5c11\n\u60a8\u7684\u623f\u5c4b\u8d37\u6b3e*\u3002\n\u5982\u679c\u60a8\u56e0\u4f24\u75c5\u6216\u975e\u81ea\u613f\u5931\u4e1a\u800c\u65e0\u6cd5\u5de5\u4f5c\uff0c\u4fdd\u9669\u8fd8\u53ef\u4ee5\u534f\u52a9\u60a8\u652f\u4ed8\u90e8\u5206\u623f\u5c4b\u8d37\u6b3e\u8fd8\u6b3e\u3002\n\u9879\u76ee \u63cf\u8ff0\n\u4fdd\u969c \u5f53\u4e2a\u4eba\u56e0\u4f24\u6b8b\u65e0\u6cd5\u5de5\u4f5c\u3001\u906d\u9047\u975e\u81ea\u613f\u5931\u4e1a\u3001\u786e\u8bca\u627f\u4fdd\u8303\u56f4\u5185\u7684\u91cd\u5927\u75be\u75c5\u6216\u8eab\u6545\u65f6\uff0c\u63d0\u4f9bCIBC\u623f\u8d37 \u8d22\u52a1\u4fdd\u969c\u3002\n\u5373\u65f6\u627f\u4fdd \u7533\u8bf7\u8868\u4e2d\u6240\u6709\u5065\u5eb7\u7b5b\u67e5\u95ee\u9898\u56de\u7b54\u5747\u4e3a\u3010\u5426\u3011\u4e14\u4e2a\u4ebaCIBC\u623f\u8d37\u83b7\u6279\u60c5\u51b5\u4e0b\uff0c\u53ef\u5373\u65f6\u901a\u8fc7\u6295\u4fdd\u5ba1\u6279\u3002\n\u4fbf\u6377 \u65e0\u9700\u5355\u72ec\u652f\u4ed8\u4fdd\u8d39\u2014\u2014\u4fdd\u8d39\u5c06\u81ea\u52a8\u8ba1\u5165\u4e2a\u4ebaCIBC\u623f\u8d37\u8fd8\u6b3e\uff0c\u623f\u8d37\u652f\u4ed8\u9891\u7387\u5982\u6709\u53d8\u66f4\uff0c\u4fdd\u8d39\u4f1a\u81ea\u52a8\u8c03\u6574\u3002\n* \u62b5\u62bc\u8d37\u6b3e\u5fc5\u987b\u4e3a\u4ee5\u4e0d\u52a8\u4ea7\u4f5c\u62b5\u62bc\u7684\u8d37\u6b3e\uff0c\u6216\u8005\u662f\u9488\u5bf9\u4f4d\u4e8e\u4fdd\u7559\u5730\uff0c\u6761\u7ea6\u571f\u5730\u6216\u539f\u4f4f\u6c11\u6240\u6709\u6743\u571f\u5730\u4e0a\u7684\u4f4f\u5b85\u7269\u4e1a\u7684\u65e0\u62c5\u4fdd\u8d37\u6b3e\u3002\n\u5927\u5199\u672f\u8bed\u7684\u5b9a\u4e49\u4ee5CIBC\u62b5\u62bc\u8d37\u6b3e\u4fdd\u9669\u8bc1\u4e66\u4e2d\u7684\u5b9a\u4e49\u4e3a\u51c6\u3002\n\u4e86\u89e3\u66f4\u591a\uff1a\n\u7acb\u5373\u54a8\u8be2CIBC\u987e\u95ee\n\u9b41\u5317\u514b\u5730\u533a\uff1a1 866 307-2555\n\u52a0\u62ff\u5927\u5176\u5b83\u5730\u533a\uff1a1 866 321-3639\n\u8bbf\u95eeCIBC\u94f6\u884c\u4e2d\u5fc3\n\u8bbf\u95eecibc.com/ creditor\n13031 Chinese \u2013 2025/06",
