        {
          "field_name": "payment_frequency",
          "candidate_value": "CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669 \u4ea7\u54c1\u6458\u8981 \u5b89\u5fc3\u5f53\u4e0b\uff0c\u4fdd\u969c\u672a\u6765\u3002 \u9009\u62e9CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd\u9669\u7684\u7406\u7531 \u5408\u9002\u7684\u4fdd\u9669\u80fd\u591f\u5e26\u6765\u5b89\u5fc3\u4fdd\u969c\uff0c\u5373\u4f7f\u672a\u6765\u4e2a\u4eba\u6536\u5165\u53d7\u5230\u5f71\u54cd\uff0c\u4e5f\u80fd\u8ba9\u81ea\u5df1\u548c\u5bb6\u4eba\u6709\u623f\u53ef\u4f4f\uff0c\u5b89\u5fc3\u65e0\u5fe7\u3002CIBC\u623f\u8d37\u503a\u6743\u4eba\u4fdd \u9669\u662f\u4e00\u79cd\u503a\u6743\u4eba\u56e2\u4f53\u4fdd\u9669\uff0c\u7531Canada Life\u4fdd\u9669\u516c\u53f8\u627f\u4fdd\u3002\u8be5\u4fdd\u9669\u53ef\u5728\u60a8\u8eab\u6545\u6216\u7f79\u60a3\u4fdd\u5355\u6db5\u76d6\u7684\u91cd\u5927\u75be\u75c5\u65f6\uff0c\u5e2e\u52a9\u507f\u8fd8\u6216\u51cf\u5c11 \u60a8\u7684\u623f\u5c4b\u8d37\u6b3e*\u3002 \u5982\u679c\u60a8\u56e0\u4f24\u75c5\u6216\u975e\u81ea\u613f\u5931\u4e1a\u800c\u65e0\u6cd5\u5de5\u4f5c\uff0c\u4fdd\u9669\u8fd8\u53ef\u4ee5\u534f\u52a9\u60a8\u652f\u4ed8\u90e8\u5206\u623f\u5c4b\u8d37\u6b3e\u8fd8\u6b3e\u3002 \u9879\u76ee \u63cf\u8ff0 \u4fdd\u969c \u5f53\u4e2a\u4eba\u56e0\u4f24\u6b8b\u65e0\u6cd5\u5de5\u4f5c\u3001\u906d\u9047\u975e\u81ea\u613f\u5931\u4e1a\u3001\u786e\u8bca\u627f\u4fdd\u8303\u56f4\u5185\u7684\u91cd\u5927\u75be\u75c5\u6216\u8eab\u6545\u65f6\uff0c\u63d0\u4f9bCIBC\u623f\u8d37 \u8d22\u52a1\u4fdd\u969c\u3002 \u5373\u65f6\u627f\u4fdd \u7533\u8bf7\u8868\u4e2d\u6240\u6709",
