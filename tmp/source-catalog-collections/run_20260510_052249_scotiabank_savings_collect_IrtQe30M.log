        {
          "field_name": "interest_calculation_method",
          "candidate_value": "F irst, you earn a Regular Interest rate (and if you have an Ultimate or Preferred Package, the applicable Package Interest Rate Boost), which is applied to your daily closing balance and is paid monthly.",
          "value_type": "string",
